	id UUID NOT NULL, 
	user_id UUID NOT NULL, 
	title VARCHAR(255), 
	description VARCHAR, 
	status imagestatus NOT NULL, 
	source_file VARCHAR(512), 
	processed_file VARCHAR(512), 
